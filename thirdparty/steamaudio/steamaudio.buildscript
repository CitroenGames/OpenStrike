[project:SteamAudio]
type = interface
headers = include/*.h
public_includes = include
if(Windows)
{
    public_libs = lib/windows-x64/phonon.lib
}
if(Linux)
{
    public_libs = lib/linux-x64/libphonon.so
}
if(macOS)
{
    public_libs = lib/osx/libphonon.dylib
}

[config:Debug|x64]
runtime_library = MultiThreadedDebug
optimization = Disabled
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/x64/Debug
intdir = ../../build/obj/x64/Debug/SteamAudio
if(Windows)
{
    postbuild = """
    if not exist ..\bin\x64\Debug\. mkdir ..\bin\x64\Debug\.
    copy /y ..\thirdparty\steamaudio\lib\windows-x64\phonon.dll ..\bin\x64\Debug\phonon.dll
    """
    postbuild_message = Copying phonon.dll for Debug runtime targets
}
if(posix)
{
    outdir = ../../bin/posix/Debug
    intdir = ../../build/obj/posix/Debug/SteamAudio
}

[config:Release|x64]
runtime_library = MultiThreaded
optimization = MaxSpeed
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/x64/Release
intdir = ../../build/obj/x64/Release/SteamAudio
if(Windows)
{
    postbuild = """
    if not exist ..\bin\x64\Release\. mkdir ..\bin\x64\Release\.
    copy /y ..\thirdparty\steamaudio\lib\windows-x64\phonon.dll ..\bin\x64\Release\phonon.dll
    """
    postbuild_message = Copying phonon.dll for Release runtime targets
}
if(posix)
{
    outdir = ../../bin/posix/Release
    intdir = ../../build/obj/posix/Release/SteamAudio
}
