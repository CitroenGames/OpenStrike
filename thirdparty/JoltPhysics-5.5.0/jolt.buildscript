[project:JoltPhysics]
type = lib
sources = Jolt/**/*.cpp
headers = Jolt/**/*.h Jolt/**/*.inl
includes = .
public_includes = .
defines = JPH_OBJECT_STREAM
if(Windows)
{
    defines = JPH_OBJECT_STREAM, JPH_USE_AVX2
    simd = AdvancedVectorExtensions2
}
if(Linux)
{
    defines = JPH_OBJECT_STREAM
    cxxflags = -pthread
    ldflags = -pthread
}
if(macOS)
{
    defines = JPH_OBJECT_STREAM
    cxxflags = -pthread
    ldflags = -pthread
}
std = 17
multiprocessor = true

[config:Debug|x64]
runtime_library = MultiThreadedDebug
optimization = Disabled
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/x64/Debug
intdir = ../../build/obj/x64/Debug/JoltPhysics
if(posix)
{
    outdir = ../../bin/posix/Debug
    intdir = ../../build/obj/posix/Debug/JoltPhysics
}

[config:Release|x64]
runtime_library = MultiThreaded
optimization = MaxSpeed
debug_info = ProgramDatabase
generate_debug_info = true
outdir = ../../bin/x64/Release
intdir = ../../build/obj/x64/Release/JoltPhysics
if(posix)
{
    outdir = ../../bin/posix/Release
    intdir = ../../build/obj/posix/Release/JoltPhysics
}
